  // Write content
  sheet.getRange(1, 1, content.length, 1).setValues(content);
  
  // Format title
  sheet.getRange(1, 1).setFontSize(18).setFontWeight("bold");
  
  // Auto-format based on content patterns
  for (let i = 0; i < content.length; i++) {
    const row = i + 1;
    const text = content[i][0];
    
    // Format divider lines (═══)
    if (text.includes("═══")) {
      sheet.getRange(row, 1).setFontFamily("Courier New").setFontColor("#888888");
    }
    
    // Format section headers (all caps, not dividers, not blank)
    if (text === text.toUpperCase() && 
        text.length > 3 && 
        !text.includes("═══") && 
        !text.includes("→") &&
        !text.startsWith("B") &&
        !text.startsWith("C") &&
        !text.startsWith("D")) {
      sheet.getRange(row, 1).setFontSize(11).setFontWeight("bold").setBackground("#f3f3f3");
    }
    
    // Format warning section and fruit order
    if (text.includes("⚠️") || text.includes("🍎")) {
      sheet.getRange(row, 1).setFontWeight("bold").setFontColor("#cc0000");
    }
  }
  
  // Freeze title row
  sheet.setFrozenRows(1);
  
  // Hide gridlines for cleaner look
  sheet.setHiddenGridlines(true);
  
  Logger.log("✅ README sheet populated successfully.");
}

