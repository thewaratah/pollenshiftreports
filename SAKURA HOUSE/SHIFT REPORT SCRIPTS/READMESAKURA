    [""],
    ["B3:D3    Date"],
    ["B4:D4    MOD (Manager on Duty)"],
    ["B6:D6    FOH Staff (dropdown)"],
    ["B7:D7    BOH Staff (dropdown)"],
    [""],
    ["═══════════════════════════════════════════════════════════════"],
    ["FIELD REFERENCE - CASH RECONCILIATION"],
    ["═══════════════════════════════════════════════════════════════"],
    [""],
    ["C10:C17  Cash Counted in Till"],
    ["D10:D17  Refloat ($500)"],
    ["C22      Cash rung up incorrectly / returned"],
    ["C23      CD - Cash Discount"],
    ["C29      Tips - Cash"],
    ["C30      Tips - Card"],
    ["C31      Tips - Surcharge"],
    [""],
    ["═══════════════════════════════════════════════════════════════"],
    ["FIELD REFERENCE - SALES RECONCILIATION"],
    ["═══════════════════════════════════════════════════════════════"],
    [""],
    ["B37      Production Amount (from Lightspeed)"],
    ["B38      Deposit / revenue outside Lightspeed"],
    ["B40:B45  Card Transactions (Woolworths, Mitre 10, etc.)"],
    ["B50      Total Discounts (from Lightspeed, includes CD)"],
    ["B54      NET REVENUE (less tips & accounts)"],
    [""],
    ["═══════════════════════════════════════════════════════════════"],
    ["FIELD REFERENCE - SHIFT REPORT"],
    ["═══════════════════════════════════════════════════════════════"],
    [""],
    ["B59      General Overview - shift summary"],
    ["B61      Guest of Note - VIPs, regulars"],
    ["B63      Good Notes - positive feedback"],
    ["B65      Issues / Improvements"],
    ["B67      Kitchen Notes (from chef)"],
    [""],
