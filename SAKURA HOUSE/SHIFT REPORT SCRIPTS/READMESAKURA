/**
 * ============================================================================
 * README SHEET CONTENT GENERATOR
 * ============================================================================
 * 
 * Run this function to populate a README sheet with formatted content.
 * Designed for the Sakura House Shift Report template.
 * 
 * USAGE:
 * 1. Create a sheet named "README" in your template
 * 2. Run populateReadmeSheet() from Apps Script
 * 3. Adjust column widths as needed (A: 600px recommended)
 * ============================================================================
 */

function populateReadmeSheet() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  let sheet = ss.getSheetByName("README");
  
  if (!sheet) {
    sheet = ss.insertSheet("README", 0);
  } else {
    sheet.clear();
  }
  
  // Set column width
  sheet.setColumnWidth(1, 700);
  
  // Content rows
  const content = [
