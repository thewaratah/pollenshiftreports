# macOS
.DS_Store

# Clasp credentials (contains script IDs)
.clasp.json
.clasprc.json

# Node
node_modules/

# Claude Code local settings (keep settings.local.json private, version-control agents/commands/skills)
.claude/settings.local.json
.claude/worktrees/
.claude/agent-memory-local/

# Setup scripts (contain Slack webhook URLs and other secrets)
**/_SETUP_*

# Archived docs (contain leaked secrets from early development)
docs/_archive/
docs/_archive_analysis/

# Service account keys (Google Cloud credentials)
mcp-sheets-*.json

# Word documents (build artifacts; .md is source of truth)
*.docx
~$*.docx

# Session state
.remember/

# IDE
.vscode/
.idea/
